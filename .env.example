# ========== 数据库 ==========
POSTGRES_USER=chief
POSTGRES_PASSWORD=chief_secret_2024
POSTGRES_DB=chief_of_staff
DATABASE_URL=postgresql+asyncpg://chief:chief_secret_2024@postgres:5432/chief_of_staff
DATABASE_URL_SYNC=postgresql://chief:chief_secret_2024@postgres:5432/chief_of_staff

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0

# ========== LLM (SiliconFlow) ==========
SILICONFLOW_API_KEY=sk-your-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL_FAST=deepseek-ai/DeepSeek-V3
LLM_MODEL_STRONG=deepseek-ai/DeepSeek-V4-Pro
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ========== 飞书 ==========
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# ========== 认证（旧版兼容；新部署请用 ADMIN_PASSWORD_HASH） ==========
AUTH_USERS=admin:changeme,ceo:changeme

# ========== 安全（生产部署必填） ==========
# Fernet 密钥 — 加密 DB 中敏感字段
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# /api/admin/* 端点 Bearer token
# 生成: openssl rand -hex 32
ADMIN_API_TOKEN=

# Streamlit admin 用户密码 bcrypt 哈希（生产模式必填）
# 生成: python -c "import bcrypt; print(bcrypt.hashpw(b'YourStrongPwd', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

# Sentry 错误追踪 DSN（可选）
SENTRY_DSN=

# ========== 应用 ==========
APP_ENV=development
LOG_LEVEL=INFO
