# ========== 数据库 ==========
POSTGRES_USER=chief
POSTGRES_PASSWORD=chief_secret_2024
POSTGRES_DB=chief_of_staff
DATABASE_URL=postgresql+asyncpg://chief:chief_secret_2024@postgres:5432/chief_of_staff
DATABASE_URL_SYNC=postgresql://chief:chief_secret_2024@postgres:5432/chief_of_staff

# ========== Redis ==========
REDIS_URL=redis://redis:6379/0

# ========== LLM (SiliconFlow) ==========
SILICONFLOW_API_KEY=sk-your-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL_FAST=deepseek-ai/DeepSeek-V3
LLM_MODEL_STRONG=deepseek-ai/DeepSeek-V4-Pro
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# ========== 飞书 ==========
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# ========== 认证（格式: 用户名:密码,用户名:密码） ==========
AUTH_USERS=admin:changeme,ceo:changeme

# ========== 应用 ==========
APP_ENV=development
LOG_LEVEL=INFO
